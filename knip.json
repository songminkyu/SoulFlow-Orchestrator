{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/bootstrap-templates.ts",
    "src/chunker/main.ts",
    "src/chunker/worker.ts",
    "src/*/index.ts",
    "src/*/**/index.ts",
    "scripts/**/*.{ts,mjs,cjs,js}",
    ".claude/hooks/**/*.mjs",
    "vitest.e2e.config.ts",
    "tests/helpers/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.{ts,mjs,cjs,js}",
    "tests/**/*.ts"
  ],
  "ignore": [
    "tests/e2e/**"
  ],
  "ignoreDependencies": ["js-yaml", "@types/ioredis"],
  "ignoreBinaries": ["knip"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "exports": "off",
    "types": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "classMembers": "off",
    "duplicates": "off",
    "dependencies": "warn",
    "devDependencies": "warn",
    "optionalPeerDependencies": "off",
    "unlisted": "off",
    "unresolved": "off"
  }
}
