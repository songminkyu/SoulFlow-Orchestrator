# Dependencies (rebuilt in container)
node_modules/
web/node_modules/

# Build outputs
dist/
standalone/

# Persistent data (volume-mounted, not baked in)
workspace/
!workspace/workflows/
*.db
*.db-wal
*.db-shm

# Development
.claude/
.git/
.vscode/
.idea/

# Environment / secrets
.env
.env.*

# Tests
tests/
**/*.test.ts
**/*.spec.ts
vitest.config.*

# Coverage
coverage/

# Temporary
*.tsbuildinfo
*.log
nul
temp_*

# Documentation (not needed at runtime)
docs/

# OS artifacts
Thumbs.db
.DS_Store
