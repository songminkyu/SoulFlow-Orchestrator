# SoulFlow Orchestrator 환경 설정 파일
# 사본을 만들어 .env로 이름 변경 후 사용하세요:
# cp .env.example .env

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗂️ 워크스페이스 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 기본 워크스페이스 경로 (컨테이너 내부)
WORKSPACE=/data

# 로컬 워크스페이스 경로 (선택사항)
# 이 경로는 docker-compose에 마운트됨
# LOCAL_WORKSPACE=/path/to/local/workspace

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🐳 Docker Compose 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 프로젝트 이름 (컨테이너 식별)
COMPOSE_PROJECT_NAME=soulflow

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔌 포트 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 웹 서버 포트
WEB_PORT=4200

# Redis 포트
REDIS_PORT=6379

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌍 애플리케이션 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Node.js 환경
NODE_ENV=development

# 디버그 모드
DEBUG=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📊 데이터베이스 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Redis 연결 URL
REDIS_URL=redis://redis:6379

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 보안 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Redis 패스워드 (프로덕션 환경에서만 필수)
# REDIS_PASSWORD=your-secure-password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 로깅 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 로그 레벨: debug, info, warn, error
LOG_LEVEL=info
