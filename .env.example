# SoulFlow Orchestrator 환경 설정 파일
# 사본을 만들어 .env로 이름 변경 후 사용하세요:
# cp .env.example .env
#
# 참고: run.sh를 사용하면 대부분의 변수가 프로필별 프리셋으로 자동 설정됩니다.
# 이 파일은 docker compose up을 직접 실행하거나 프리셋을 오버라이드할 때 사용합니다.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗂️ 워크스페이스 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 호스트 워크스페이스 경로 (컨테이너에 /data로 마운트됨)
# HOST_WORKSPACE=/path/to/local/workspace

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🐳 Docker Compose 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 프로젝트 이름 (컨테이너·네트워크 식별)
PROJECT_NAME=soulflow

# 빌드 타겟: dev | production | full
BUILD_TARGET=full

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔌 포트 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 웹 서버 포트
WEB_PORT=4200

# Redis 호스트 포트 (컨테이너 내부는 항상 6379)
REDIS_PORT=6379

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌍 애플리케이션 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Node.js 환경
NODE_ENV=development

# 디버그 모드
DEBUG=true

# 로그 레벨: debug, info, warn, error
LOG_LEVEL=info

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📊 Redis / 메시지 버스
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Redis 연결 URL (외부 Redis 사용 시 변경)
REDIS_URL=redis://redis:6379

# 메시지 버스 백엔드: memory | redis
BUS_BACKEND=redis

# 메시지 버스 Redis URL (REDIS_URL과 별도 인스턴스 사용 시)
# BUS_REDIS_URL=redis://redis:6379

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📦 리소스 제한
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Orchestrator
MEMORY=1G
CPUS=2
NODE_HEAP_MB=768

# Chunker
CHUNKER_MEMORY=512M
CHUNKER_CPUS=1
CHUNKER_HEAP_MB=512
