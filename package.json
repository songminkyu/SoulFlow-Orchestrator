{
  "name": "soulflow-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:coverage": "vitest run --coverage --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run test",
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "dev:once": "tsx src/main.ts",
    "health:llm": "tsx src/orchestrator-llm-health.ts",
    "docker:build": "node -e \"process.env.DOCKER_BUILDKIT='0';require('child_process').execSync('docker compose -f docker/docker-compose.yml build',{stdio:'inherit'})\"",
    "docker:down": "docker compose -f docker/docker-compose.yml down -v"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@slack/web-api": "^7.14.1",
    "@vercel/beautiful-mermaid": "^0.1.5",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "markdown-to-markdown-sanitizer": "^1.1.3",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71"
  },
  "overrides": {
    "express-rate-limit": "^8.3.0"
  }
}
