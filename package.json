{
  "name": "soulflow-orchestrator",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "author": "Hyun Park",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:changed": "vitest run --changed HEAD",
    "test:coverage": "vitest run --coverage --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run test",
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "dev:once": "tsx src/main.ts",
    "health:llm": "tsx src/orchestrator-llm-health.ts",
    "container:build": "node scripts/container.cjs compose:build",
    "container:up": "node scripts/container.cjs compose:up",
    "container:down": "node scripts/container.cjs compose:down",
    "container:logs": "node scripts/container.cjs compose:logs",
    "container:restart": "node scripts/container.cjs compose:restart",
    "eval:smoke": "tsx scripts/eval-run.ts --smoke --threshold 80",
    "eval:routing": "tsx scripts/eval-run.ts --bundle routing",
    "eval:compiler": "tsx scripts/eval-run.ts --bundle compiler",
    "eval:full": "tsx scripts/eval-run.ts --full --threshold 70",
    "feedback:audit": "node scripts/feedback-audit.mjs",
    "feedback:respond": "node scripts/feedback-respond.mjs",
    "feedback:loop": "node scripts/feedback-audit.mjs",
    "check:knip": "knip",
    "check:types": "vitest run tests/repo-profile/types.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "fast-check": "^4.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@slack/web-api": "^7.14.1",
    "@vercel/beautiful-mermaid": "^0.1.5",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.11.0",
    "markdown-to-markdown-sanitizer": "^1.1.3",
    "minimatch": "^10.2.4",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71"
  },
  "overrides": {
    "express-rate-limit": "^8.3.0"
  }
}
